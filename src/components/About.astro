---
// 关于我 + AI 能力栈
const skillStack = [
  {
    label: 'AI 应用架构',
    items: ['RAG', 'Agent 工作流', 'Function Calling', 'LangChain / LangGraph', 'Multi-Agent 协同'],
  },
  {
    label: '检索与知识工程',
    items: ['文档分块策略', '向量检索', 'Markdown / KV 结构化', '知识库质量优化'],
  },
  {
    label: '评测与迭代',
    items: ['Eval 体系', 'LLM-as-Judge', '人工标注', '规则判分', 'Badcase 回流', '线上效果监控'],
  },
  {
    label: '模型选型与优化',
    items: ['Qwen / DeepSeek / Claude / GPT', 'Prompt 工程', '成本 / 延迟 / 效果权衡', '本地化部署'],
  },
  {
    label: '端侧 AI',
    items: ['MobileNetV3', 'INT8 量化', '板端推理', '模型 Benchmark', '降级策略'],
  },
  {
    label: '产品与数据工具',
    items: ['Figma · Stitch', 'Python 数据分析', 'A/B 测试', '指标体系设计'],
  },
];
---

<section class="about" id="about">
  <div class="container">
    <div class="about-head">
      <span class="eyebrow">01 — About</span>
      <h2 class="about-title display display-md">
        我如何把 AI<br/>
        做成<em>可上线的产品</em>
      </h2>
    </div>

    <div class="about-grid">
      <!-- 左侧文字 -->
      <div class="about-text">
        <p class="body-text-lg">
          我的核心工作不是把 AI 包装成概念，而是把业务目标拆成
          <span class="accent">可评测、可上线、可复盘</span>的产品流程。
          让模型能力进入真实业务，并能被团队持续迭代。
        </p>
        <p class="body-text">
          过去 4 年，我经历了 C 端电商策略、智能硬件软硬一体、企业级 Multi-Agent 工作流三个阶段：
          从 PDD 把策略迭代周期从<strong class="text-strong">周级压到天级</strong>，
          到伊赛尔<strong class="text-strong">92%+ 找星成功率</strong>、单季营收 +35%，
          再到 TILTA 首稿可用率<strong class="text-strong">40%→70%+</strong>。
        </p>
        <p class="body-text muted">
          这些项目的底层都是同一个问题：
          <span class="accent">如何把模糊需求拆成 AI 能稳定交付、业务能量化验证的产品能力。</span>
          这也是我一边做企业 B 端项目、一边自研 C 端 Eatit 的原因。
        </p>

        <div class="about-tags">
          <span class="tag tag-accent">Multi-Agent</span>
          <span class="tag tag-accent">RAG</span>
          <span class="tag tag-accent">Eval 体系</span>
          <span class="tag tag-mint">Prompt 工程</span>
          <span class="tag tag-mint">端侧 AI</span>
          <span class="tag tag-mint">Context Engineering</span>
        </div>
      </div>

      <!-- 右侧基本信息卡 -->
      <aside class="about-side">
        <div class="info-card">
          <div class="info-row">
            <span class="info-label">定位</span>
            <span class="info-value">AI 产品经理 / Agent 应用方向</span>
          </div>
          <div class="info-row">
            <span class="info-label">经验</span>
            <span class="info-value">4 年产品经验 / 近 3 年 AI 产品实践</span>
          </div>
          <div class="info-row">
            <span class="info-label">能力</span>
            <span class="info-value">Agent 工作流 · RAG · Eval · 端侧 AI</span>
          </div>
          <div class="info-row">
            <span class="info-label">交付</span>
            <span class="info-value">需求拆解 → 原型验证 → 上线迭代</span>
          </div>
        </div>

        <div class="quote-card">
          <span class="quote-mark">"</span>
          <p>
            判断一个需求是否值得用 AI ，我有三个原则：
            <span class="accent">高频、耗时、可标准化。</span>
            主动排除强主观判断的场景，让 AI 做稳定能做好的事。
          </p>
          <span class="quote-author mono">— 我的产品工作笔记</span>
        </div>
      </aside>
    </div>

    <div class="career-arc">
      <span class="eyebrow">— Career Arc</span>
      <h3 class="heading heading-lg arc-title">从经验决策到 AI 决策的 4 年</h3>

      <div class="arc-track">
        <div class="arc-stage">
          <div class="arc-period mono">2022 — 2023</div>
          <div class="arc-dot"></div>
          <h4 class="arc-stage-title">策略产品 · 经验 → 数据决策</h4>
          <p class="arc-stage-desc">拼多多发券链路，从人工经验配置升级为多维分层与算法推荐，让策略判断开始建立在可验证数据上。</p>
        </div>
        <div class="arc-arrow">→</div>
        <div class="arc-stage">
          <div class="arc-period mono">2023 — 2024</div>
          <div class="arc-dot"></div>
          <h4 class="arc-stage-title">AIGC + LLM Copilot · 数据 → AI 决策</h4>
          <p class="arc-stage-desc">从素材自动化生产到 LLM 驱动的运营策略 Copilot，把数据洞察与日常策略分析链路逐步 AI 化。</p>
        </div>
        <div class="arc-arrow">→</div>
        <div class="arc-stage">
          <div class="arc-period mono">2024 — Now</div>
          <div class="arc-dot arc-dot-active"></div>
          <h4 class="arc-stage-title">端侧 AI + Multi-Agent · AI 原生产品</h4>
          <p class="arc-stage-desc">伊赛尔端侧软硬一体、TILTA 企业级 Multi-Agent，再到自研 Eatit，验证同一套方法论可以跨场景复用。</p>
        </div>
      </div>
    </div>

    <!-- 能力栈 -->
    <div class="skills-block">
      <span class="eyebrow" style="margin-bottom: 24px;">— Skill Stack</span>

      <div class="skills-grid">
        {skillStack.map((cat, idx) => (
          <div class="skill-cat">
            <div class="skill-cat-head">
              <span class="skill-num mono">{String(idx + 1).padStart(2, '0')}</span>
              <h3 class="skill-cat-title">{cat.label}</h3>
            </div>
            <ul class="skill-items">
              {cat.items.map((it) => <li>{it}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-head {
    margin-bottom: 80px;
    max-width: 100%;
  }

  .about-title {
    margin-top: 24px;
    max-width: 16ch;
  }

  .nowrap {
    white-space: nowrap;
  }

  .about-title em {
    font-style: normal;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
    margin-bottom: 120px;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .about-side {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .info-card {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 24px;
    background: var(--bg-elev-1);
  }

  .info-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }

  .info-row:first-child { padding-top: 0; }
  .info-row:last-child { border-bottom: 0; padding-bottom: 0; }

  .info-label {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--ink-500);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    flex: 0 0 60px;
    padding-top: 2px;
  }

  .info-value {
    font-size: 14px;
    color: var(--ink-100);
    flex: 1;
    line-height: 1.5;
  }

  .quote-card {
    position: relative;
    padding: 28px 24px 24px;
    border-radius: var(--r-lg);
    background: linear-gradient(135deg, var(--accent-cyan-soft), transparent);
    border: 1px solid var(--line-accent);
  }

  .quote-mark {
    position: absolute;
    top: 0;
    left: 16px;
    font-family: var(--f-display);
    font-size: 80px;
    line-height: 1;
    color: var(--accent-cyan);
    opacity: 0.5;
    font-style: italic;
  }

  .quote-card p {
    font-family: var(--f-body);
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-100);
    margin-bottom: 16px;
    font-style: normal;
  }

  .quote-author {
    font-size: 11px;
    color: var(--ink-500);
    letter-spacing: 0.05em;
  }

  .career-arc {
    border-top: 1px solid var(--line);
    padding-top: 64px;
    margin-bottom: 80px;
  }

  .arc-title {
    margin-top: 16px;
    margin-bottom: 40px;
    max-width: 24ch;
  }

  .arc-track {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 24px;
    align-items: stretch;
  }

  .arc-stage {
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: var(--bg-elev-1);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 300ms;
  }

  .arc-stage:hover {
    border-color: var(--line-accent);
    transform: translateY(-2px);
  }

  .arc-period {
    font-size: 11px;
    color: var(--ink-500);
    letter-spacing: 0.05em;
  }

  .arc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink-600);
    margin-bottom: 4px;
  }

  .arc-dot-active {
    background: var(--accent-mint);
    box-shadow: 0 0 12px var(--accent-mint);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  .arc-stage-title {
    font-size: 15px;
    color: var(--ink-100);
    font-weight: 600;
    line-height: 1.45;
  }

  .arc-stage-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-400);
  }

  .arc-arrow {
    align-self: center;
    color: var(--accent-cyan);
    font-size: 18px;
    opacity: 0.4;
  }

  /* 能力栈区域 */
  .skills-block {
    border-top: 1px solid var(--line);
    padding-top: 64px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 24px;
  }

  .skill-cat {
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: var(--bg-elev-1);
    transition: all 300ms;
    position: relative;
    overflow: hidden;
  }

  .skill-cat::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-cyan-soft), transparent 60%);
    opacity: 0;
    transition: opacity 300ms;
    pointer-events: none;
  }

  .skill-cat:hover {
    border-color: var(--line-accent);
    transform: translateY(-2px);
  }
  .skill-cat:hover::before { opacity: 1; }

  .skill-cat-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
    position: relative;
  }

  .skill-num {
    font-size: 12px;
    color: var(--accent-cyan);
    letter-spacing: 0.05em;
  }

  .skill-cat-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink-100);
  }

  .skill-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
  }

  .skill-items li {
    font-size: 13.5px;
    color: var(--ink-200);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .skill-items li::before {
    content: '·';
    color: var(--accent-cyan);
    position: absolute;
    left: 4px;
    font-weight: bold;
  }

  @media (max-width: 1024px) {
    .about-grid { grid-template-columns: 1fr; gap: 32px; }
    .about-side { position: static; }
    .arc-track { grid-template-columns: 1fr; }
    .arc-arrow {
      transform: rotate(90deg);
      justify-self: flex-start;
      margin-left: 24px;
      opacity: 0.3;
    }
    .skills-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .skills-grid { grid-template-columns: 1fr; }
    .about-head { margin-bottom: 48px; }
  }
</style>
