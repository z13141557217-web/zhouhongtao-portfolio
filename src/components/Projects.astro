---
import { projects } from '../data/projects';

const workProjects = projects;
const isCountableValue = (value: string) => /^[+\-−]?\d+(?:\.\d+)?(?:[^\d→]*)$/.test(value.trim());
---

<section class="projects" id="projects">
  <div class="container">
    <div class="projects-head">
      <span class="eyebrow">02 — Selected Work</span>
      <h2 class="display display-md projects-title">
        4 段真实业务里的<br/>
        <em>AI 产品实践</em>
      </h2>
      <p class="body-text-lg muted projects-intro">
        以下 4 段项目按时间倒序排列，覆盖企业 B 端 Multi-Agent / 端侧 AI 软硬一体 / C 端电商策略三类场景。
        每段都有可量化的业务成果与对应的方法论沉淀。
      </p>
    </div>

    <!-- 重点项目 - 大卡片 -->
    <div class="featured-projects">
      {workProjects.filter(p => p.featured).map((p, idx) => (
        <article class={`featured-card accent-${p.accent}`} id={p.id}>
          <div class="featured-meta">
            <span class="featured-num mono">{`P0${idx + 1}`}</span>
            <div class="featured-period">
              <span class="mono">{p.period}</span>
              <span class="featured-co">{p.company} · {p.role}</span>
            </div>
          </div>

          <h3 class="featured-title">{p.title}</h3>

          <p class="featured-summary">{p.summary}</p>

          <div class="featured-tags">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>

          <div class="featured-metrics">
            {p.metrics.map(m => (
              <div class="metric">
                <span class="stat-num metric-value" data-countup={isCountableValue(m.value) ? 'true' : undefined}>{m.value}</span>
                <span class="metric-label mono">{m.label}</span>
              </div>
            ))}
          </div>

          <a href={p.detail ? `/projects/${p.id}/` : `#${p.id}`} class="featured-cta">
            <span class="featured-cta-dot"></span>
            <span>查看完整复盘</span>
            <span class="featured-cta-arrow">→</span>
          </a>
        </article>
      ))}
    </div>

    <!-- 次要项目 - 紧凑列表 -->
    <div class="compact-section">
      <h3 class="compact-head">
        <span class="eyebrow">— 拼多多时期 · AI 在电商策略的两次跳跃</span>
      </h3>
      <p class="muted compact-intro">
        从 AIGC 文案自动化生产，到 LLM 驱动的运营策略 Copilot——
        我在拼多多经历了 AI 在电商策略场景从「<span class="text-strong">辅助生产</span>」
        到「<span class="text-strong">辅助决策</span>」的两次跳跃。
        这条主线也是我现在做 Multi-Agent 项目的实践起点。
      </p>

      <div class="compact-grid">
        {workProjects.filter(p => !p.featured).map((p, idx) => (
          <article class={`compact-card accent-${p.accent}`} id={p.id}>
            <div class="compact-period mono">{p.period}</div>
            <h4 class="compact-title">{p.title}</h4>
            <p class="compact-summary muted">{p.summary}</p>
            <div class="compact-metrics">
              {p.metrics.map(m => (
                <div class="compact-metric">
                  <span class="cm-value mono" data-countup={isCountableValue(m.value) ? 'true' : undefined}>{m.value}</span>
                  <span class="cm-label">{m.label}</span>
                </div>
              ))}
            </div>
            <div class="compact-tags">
              {p.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
            </div>
            {p.detail && (
              <a href={`/projects/${p.id}/`} class="compact-cta">
                <span>查看完整复盘</span>
                <span class="featured-cta-arrow">→</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .projects-head {
    margin-bottom: 80px;
  }

  .projects-title {
    margin-top: 24px;
    margin-bottom: 24px;
    max-width: 17ch;
  }

  .projects-title em {
    font-style: normal;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .projects-intro {
    max-width: 60ch;
  }

  /* ==== 重点项目 ==== */
  .featured-projects {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-bottom: 120px;
  }

  .featured-card {
    position: relative;
    padding: clamp(32px, 5vw, 56px);
    border: 1px solid var(--line);
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, var(--bg-elev-1) 0%, var(--bg-elev-2) 100%);
    overflow: hidden;
    transition: all 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* 装饰条 */
  .featured-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent-cyan);
    opacity: 0.6;
  }

  .accent-mint::before { background: var(--accent-mint); }

  /* 角落装饰 */
  .featured-card::after {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent-cyan-soft), transparent 70%);
    pointer-events: none;
    opacity: 0.4;
    transition: opacity 400ms;
  }

  .accent-mint.featured-card::after {
    background: radial-gradient(circle, var(--accent-mint-soft), transparent 70%);
  }

  .featured-card:hover {
    transform: translateY(-3px);
    border-color: var(--line-accent);
  }
  .featured-card:hover::after { opacity: 0.7; }

  .featured-meta {
    display: flex;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .featured-num {
    font-size: 14px;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .accent-mint .featured-num { color: var(--accent-mint); }

  .featured-period {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .featured-period .mono {
    font-size: 12px;
    color: var(--ink-500);
    letter-spacing: 0.05em;
  }

  .featured-co {
    font-size: 13px;
    color: var(--ink-200);
  }

  .featured-title {
    font-family: var(--f-body);
    font-size: clamp(24px, 2.8vw, 36px);
    font-weight: 600;
    line-height: 1.28;
    letter-spacing: 0;
    color: var(--ink-100);
    margin-bottom: 20px;
    max-width: 30ch;
    position: relative;
  }

  .featured-summary {
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-200);
    max-width: 64ch;
    margin-bottom: 24px;
    position: relative;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
    position: relative;
  }

  .featured-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 28px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 28px;
    position: relative;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .metric-value {
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.08;
  }

  .metric-label {
    font-size: 11px;
    color: var(--ink-500);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--accent-cyan);
    letter-spacing: 0.05em;
    position: relative;
    cursor: pointer;
    opacity: 1;
    text-decoration: none;
    transition: gap 200ms ease, opacity 200ms ease, color 200ms ease;
  }

  .featured-cta:hover {
    gap: 12px;
    opacity: 1;
  }

  .featured-cta-arrow {
    transition: transform 200ms ease;
  }

  .featured-cta:hover .featured-cta-arrow {
    transform: translateX(2px);
  }

  /* ==== 紧凑项目 ==== */
  .compact-section {
    border-top: 1px solid var(--line);
    padding-top: 64px;
  }

  .compact-head { margin-bottom: 16px; }

  .compact-intro {
    max-width: 64ch;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .compact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    max-width: 880px;
  }

  .compact-card {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: var(--bg-elev-1);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 300ms;
    position: relative;
  }

  .compact-card:hover {
    border-color: var(--line-accent);
    background: var(--bg-elev-2);
    transform: translateY(-2px);
  }

  .compact-period {
    font-size: 11px;
    color: var(--accent-cyan);
    letter-spacing: 0.06em;
  }

  .accent-mint .compact-period { color: var(--accent-mint); }

  .compact-title {
    font-family: var(--f-body);
    font-size: 17px;
    font-weight: 600;
    color: var(--ink-100);
    line-height: 1.3;
    letter-spacing: 0;
  }

  .compact-summary {
    font-size: 13px;
    line-height: 1.6;
    flex: 1;
  }

  .compact-metrics {
    display: flex;
    gap: 14px;
    padding: 12px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
  }

  .compact-metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 70px;
  }

  .cm-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-mint);
  }

  .cm-label {
    font-size: 10.5px;
    color: var(--ink-500);
  }

  .compact-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .compact-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--accent-cyan);
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: gap 200ms ease, color 200ms ease;
  }

  .compact-cta:hover {
    gap: 12px;
  }

  .compact-tags .tag {
    font-size: 10.5px;
    padding: 3px 8px;
  }

  @media (max-width: 1024px) {
    .compact-grid { grid-template-columns: repeat(2, 1fr); max-width: 100%; }
  }

  @media (max-width: 640px) {
    .featured-metrics { grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .metric-value { font-size: 24px; }
    .compact-grid { grid-template-columns: 1fr; }
    .featured-meta { gap: 16px; }
  }
</style>
