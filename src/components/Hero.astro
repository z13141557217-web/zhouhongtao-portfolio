---
// Hero 区
---

<section class="hero" id="top">
  <!-- 装饰: 网格背景 -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- 装饰: 浮动几何 -->
  <div class="hero-orbit" aria-hidden="true">
    <div class="orbit orbit-1"></div>
    <div class="orbit orbit-2"></div>
    <div class="orbit orbit-3"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-meta reveal" style="animation-delay: 100ms;">
      <span class="status-dot"></span>
      <span class="mono">Available · Shenzhen / Remote · 2026</span>
    </div>

    <h1 class="hero-title reveal" style="animation-delay: 200ms;">
      把<em>大模型能力</em><br/>
      翻译成<em>业务可用</em>的<br/>
      <span class="title-accent">产品体验。</span>
    </h1>

    <p class="hero-sub reveal" style="animation-delay: 400ms;">
      4 年 AI 产品经验，我更像是业务与模型之间的翻译者。
      <span class="muted">把模糊需求拆成可评测、可迭代、可上线的产品能力，再用数据闭环验证它是否真的解决问题。</span>
    </p>

    <div class="hero-actions reveal" style="animation-delay: 600ms;">
      <a href="#projects" class="btn btn-primary">
        <span>查看项目</span>
        <span class="btn-arrow">↓</span>
      </a>
      <a href="/eatit-demo/" target="_blank" class="btn">
        <span class="live-dot"></span>
        <span>体验 Eatit Demo</span>
        <span class="btn-arrow">↗</span>
      </a>
    </div>

    <!-- 横向数据条 -->
    <div class="hero-stats reveal" style="animation-delay: 800ms;">
      <div class="stat">
        <span class="stat-num">70<small>%+</small></span>
        <span class="stat-label">TILTA 首稿可用率 · 40→70</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">92<small>%+</small></span>
        <span class="stat-label">伊赛尔 首次找星成功率</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">1.8</span>
        <span class="stat-label">PDD 综合 ROI · 1.2→1.8</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">+35<small>%</small></span>
        <span class="stat-label">伊赛尔 单季营收环比</span>
      </div>
    </div>
  </div>

  <!-- 滚动提示 -->
  <div class="scroll-hint" aria-hidden="true">
    <span class="mono">SCROLL</span>
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding-top: 120px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* 网格背景 - 科技感 */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, black 30%, transparent 80%);
    pointer-events: none;
  }

  /* 浮动几何装饰 */
  .hero-orbit {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .orbit {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.45;
    animation: floatOrbit 18s ease-in-out infinite;
  }
  .orbit-1 {
    width: 320px;
    height: 320px;
    background: var(--accent-cyan);
    top: 10%;
    right: -8%;
    animation-delay: 0s;
  }
  .orbit-2 {
    width: 240px;
    height: 240px;
    background: var(--accent-violet);
    bottom: 15%;
    left: -6%;
    animation-delay: -6s;
    opacity: 0.3;
  }
  .orbit-3 {
    width: 180px;
    height: 180px;
    background: var(--accent-mint);
    top: 55%;
    right: 25%;
    animation-delay: -12s;
    opacity: 0.18;
  }

  @keyframes floatOrbit {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.05); }
    66% { transform: translate(-30px, 20px) scale(0.95); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--bg-glass);
    border: 1px solid var(--line);
    backdrop-filter: blur(12px);
    margin-bottom: 36px;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--ink-400);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-mint);
    box-shadow: 0 0 12px var(--accent-mint);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(40px, 8vw, 96px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink-100);
    margin-bottom: 36px;
    max-width: 18ch;
  }

  .hero-title em {
    font-style: italic;
    background: var(--grad-cyan-violet);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 400;
  }

  .title-accent {
    font-style: italic;
    color: var(--accent-cyan);
    position: relative;
    display: inline-block;
  }

  .title-accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 0.06em;
    background: var(--accent-cyan);
    opacity: 0.4;
  }

  .hero-sub {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.7;
    color: var(--ink-200);
    max-width: 60ch;
    margin-bottom: 48px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 80px;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-mint);
    box-shadow: 0 0 8px var(--accent-mint);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  /* 数据条 */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 40px);
    flex-wrap: wrap;
    padding: 28px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    min-width: 140px;
  }

  .stat .stat-num {
    font-size: clamp(34px, 4.5vw, 56px);
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .stat .stat-num small {
    font-size: 0.45em;
    font-style: normal;
    margin-left: 2px;
  }

  .stat-label {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--ink-500);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stat-div {
    width: 1px;
    height: 40px;
    background: var(--line);
  }

  /* 滚动提示 */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: var(--f-mono);
    font-size: 10px;
    color: #6b7088;
    letter-spacing: 0.2em;
    z-index: 2;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, #6b7088, transparent);
    animation: scrollHint 2s ease-in-out infinite;
  }

  @keyframes scrollHint {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 100px; min-height: auto; }
    .hero-stats { gap: 16px 24px; }
    .stat-div { display: none; }
    .stat { min-width: calc(50% - 12px); }
    .scroll-hint { display: none; }
    .orbit-3 { display: none; }
  }
</style>
