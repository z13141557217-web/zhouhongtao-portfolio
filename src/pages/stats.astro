---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="网站数据看板 · 周鸿涛"
  description="周鸿涛个人网站轻量访问与点击数据看板。"
  noindex
>
  <Nav />
  <main id="main" class="stats-page">
    <section class="container stats-shell">
      <div class="stats-head">
        <span class="eyebrow">Analytics Dashboard</span>
        <div class="stats-title-row">
          <div>
            <h1 class="display display-md stats-title">网站点击数据看板</h1>
            <p class="body-text-lg muted stats-sub">
              只统计匿名访问与关键按钮点击，不记录 IP、不采集个人身份信息。
            </p>
          </div>
          <button class="btn btn-primary stats-refresh" type="button" id="stats-refresh">
            <span>刷新数据</span>
            <span class="btn-arrow">↻</span>
          </button>
        </div>
      </div>

      <div class="stats-warning" id="stats-warning" hidden>
        <span class="accent mono">SETUP</span>
        <p>
          看板代码已就绪，但还没有接入 Redis 存储。配置
          <code>UPSTASH_REDIS_REST_URL</code> 和 <code>UPSTASH_REDIS_REST_TOKEN</code>
          后，线上访问和点击会开始真实累计。
        </p>
      </div>

      <div class="stats-kpis" aria-live="polite">
        <article class="kpi-card">
          <span class="kpi-label mono">PAGE VIEWS</span>
          <strong class="kpi-value" data-stat="pageViews">--</strong>
          <span class="kpi-help muted">总页面访问</span>
        </article>
        <article class="kpi-card">
          <span class="kpi-label mono">VISITORS</span>
          <strong class="kpi-value" data-stat="uniqueVisitors">--</strong>
          <span class="kpi-help muted">匿名访客数</span>
        </article>
        <article class="kpi-card">
          <span class="kpi-label mono">RESUME</span>
          <strong class="kpi-value" data-stat="resumeDownloads">--</strong>
          <span class="kpi-help muted">简历下载</span>
        </article>
        <article class="kpi-card">
          <span class="kpi-label mono">PROJECTS</span>
          <strong class="kpi-value" data-stat="projectOpens">--</strong>
          <span class="kpi-help muted">项目复盘点击</span>
        </article>
        <article class="kpi-card">
          <span class="kpi-label mono">EATIT</span>
          <strong class="kpi-value" data-stat="eatitDemoOpens">--</strong>
          <span class="kpi-help muted">原型入口点击</span>
        </article>
        <article class="kpi-card">
          <span class="kpi-label mono">CONTACT</span>
          <strong class="kpi-value" data-stat="contactClicks">--</strong>
          <span class="kpi-help muted">联系动作</span>
        </article>
      </div>

      <section class="stats-panel">
        <div class="panel-head">
          <h2 class="heading heading-md">近 14 天趋势</h2>
          <span class="muted mono" id="stats-updated">LOADING</span>
        </div>
        <div class="daily-bars" id="daily-bars"></div>
      </section>

      <div class="stats-grid">
        <section class="stats-panel">
          <div class="panel-head">
            <h2 class="heading heading-md">热门页面</h2>
            <span class="muted mono">TOP PAGES</span>
          </div>
          <div class="stat-list" id="top-pages"></div>
        </section>

        <section class="stats-panel">
          <div class="panel-head">
            <h2 class="heading heading-md">关键动作</h2>
            <span class="muted mono">TOP CLICKS</span>
          </div>
          <div class="stat-list" id="top-actions"></div>
        </section>
      </div>

      <section class="stats-panel">
        <div class="panel-head">
          <h2 class="heading heading-md">事件总览</h2>
          <span class="muted mono">EVENTS</span>
        </div>
        <div class="event-grid" id="event-grid"></div>
      </section>
    </section>
  </main>
</Layout>

<style>
  .stats-page {
    min-height: 100vh;
    padding: 128px 0 96px;
  }

  .stats-shell {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .stats-head {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }

  .stats-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-top: 24px;
  }

  .stats-title { margin-bottom: 14px; }
  .stats-sub { max-width: 56ch; }
  .stats-refresh { flex-shrink: 0; }

  .stats-warning {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    padding: 18px 20px;
    border: 1px dashed var(--line-accent);
    border-radius: var(--r-md);
    background: var(--accent-cyan-soft);
  }

  .stats-warning p {
    color: var(--ink-200);
    font-size: 14px;
    line-height: 1.7;
  }

  code {
    font-family: var(--f-mono);
    font-size: 0.9em;
    color: var(--accent-mint);
  }

  .stats-kpis {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 14px;
  }

  .kpi-card,
  .stats-panel {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: linear-gradient(135deg, var(--bg-elev-1), rgba(24, 29, 53, 0.72));
    box-shadow: var(--shadow-card);
  }

  .kpi-card {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .kpi-label {
    color: var(--accent-cyan);
    font-size: 10px;
    letter-spacing: 0.12em;
  }

  .kpi-value {
    font-family: var(--f-display);
    font-size: clamp(30px, 3vw, 44px);
    font-weight: 600;
    line-height: 1.08;
    color: var(--ink-100);
  }

  .kpi-help { font-size: 12px; }

  .stats-panel {
    padding: 24px;
  }

  .panel-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .panel-head .mono {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .daily-bars {
    display: grid;
    grid-template-columns: repeat(14, minmax(0, 1fr));
    gap: 10px;
    align-items: end;
    min-height: 180px;
  }

  .daily-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    min-width: 0;
  }

  .bar-track {
    width: 100%;
    min-height: 128px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    border-bottom: 1px solid var(--line);
  }

  .bar-fill {
    width: min(28px, 70%);
    height: var(--bar-h);
    min-height: 3px;
    border-radius: 999px 999px 2px 2px;
    background: var(--grad-mint-cyan);
    box-shadow: 0 0 18px rgba(0, 229, 255, 0.18);
  }

  .bar-label,
  .bar-value {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-500);
    white-space: nowrap;
  }

  .bar-value { color: var(--ink-200); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .stat-list,
  .event-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .stat-row,
  .event-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 12px 0;
    border-top: 1px solid var(--line);
  }

  .stat-row:first-child,
  .event-row:first-child {
    border-top: 0;
  }

  .stat-name {
    color: var(--ink-200);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stat-count {
    font-family: var(--f-mono);
    color: var(--accent-mint);
    font-weight: 600;
  }

  .empty-state {
    color: var(--ink-500);
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .stats-kpis { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .stats-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .stats-page { padding-top: 104px; }
    .stats-title-row { flex-direction: column; align-items: flex-start; }
    .stats-refresh { width: 100%; justify-content: center; }
    .stats-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .daily-bars { gap: 6px; overflow-x: auto; padding-bottom: 4px; }
    .daily-bar { min-width: 36px; }
  }
</style>

<script>
  type Snapshot = {
    configured: boolean;
    generatedAt: string;
    totals: Record<string, number>;
    events: Array<{ label: string; count: number }>;
    pages: Array<{ path: string; count: number }>;
    actions: Array<{ label: string; count: number }>;
    daily: Array<{ date: string; pageViews: number; uniqueVisitors: number }>;
  };

  const formatter = new Intl.NumberFormat('zh-CN');

  function text(selector: string, value: string) {
    const el = document.querySelector(selector);
    if (el) el.textContent = value;
  }

  function listRows(root: HTMLElement, items: Array<{ name: string; count: number }>) {
    root.innerHTML = '';
    if (items.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'empty-state';
      empty.textContent = '还没有数据。上线后有人访问/点击，这里会自动出现。';
      root.appendChild(empty);
      return;
    }

    for (const item of items) {
      const row = document.createElement('div');
      const name = document.createElement('span');
      const count = document.createElement('span');

      row.className = 'stat-row';
      name.className = 'stat-name';
      name.title = item.name;
      name.textContent = item.name;
      count.className = 'stat-count';
      count.textContent = formatter.format(item.count);

      row.append(name, count);
      root.appendChild(row);
    }
  }

  function renderDaily(root: HTMLElement, daily: Snapshot['daily']) {
    root.innerHTML = '';
    const max = Math.max(1, ...daily.map((day) => day.pageViews));

    for (const day of daily) {
      const height = Math.max(3, Math.round((day.pageViews / max) * 128));
      const label = day.date.slice(5).replace('-', '/');
      const item = document.createElement('div');
      item.className = 'daily-bar';
      item.innerHTML = `
        <span class="bar-value">${formatter.format(day.pageViews)}</span>
        <div class="bar-track" title="${day.date} · ${day.pageViews} PV · ${day.uniqueVisitors} UV">
          <div class="bar-fill" style="--bar-h: ${height}px"></div>
        </div>
        <span class="bar-label">${label}</span>
      `;
      root.appendChild(item);
    }
  }

  async function loadStats() {
    text('#stats-updated', 'LOADING');
    const res = await fetch('/api/stats', { cache: 'no-store' });
    const data = (await res.json()) as Snapshot;

    document.getElementById('stats-warning')?.toggleAttribute('hidden', data.configured);

    for (const [key, value] of Object.entries(data.totals)) {
      text(`[data-stat="${key}"]`, formatter.format(value));
    }

    renderDaily(document.getElementById('daily-bars') as HTMLElement, data.daily);
    listRows(
      document.getElementById('top-pages') as HTMLElement,
      data.pages.map((item) => ({ name: item.path, count: item.count })),
    );
    listRows(
      document.getElementById('top-actions') as HTMLElement,
      data.actions.map((item) => ({ name: item.label, count: item.count })),
    );
    listRows(
      document.getElementById('event-grid') as HTMLElement,
      data.events.map((item) => ({ name: item.label, count: item.count })),
    );

    const updated = new Date(data.generatedAt).toLocaleString('zh-CN', {
      hour12: false,
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
    text('#stats-updated', `UPDATED ${updated}`);
  }

  document.getElementById('stats-refresh')?.addEventListener('click', () => void loadStats());
  void loadStats();
</script>
